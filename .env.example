# RAG backend config
#
# Put real values in GitHub repository Variables/Secrets for Actions:
# - RAG_BACKEND_URL: repository variable
# - RAG_REINDEX_ENDPOINT: repository variable
# - RAG_BACKEND_TOKEN: repository secret
#
# For local testing, copy this file to .env and fill in the values.

RAG_BACKEND_URL=https://your-rag-backend.example.com
RAG_REINDEX_ENDPOINT=/admin/rag/reindex
RAG_BACKEND_TOKEN=replace-with-a-secret-token

# Frontend chat widget config
VITE_RAG_BACKEND_URL=https://your-rag-backend.example.com
